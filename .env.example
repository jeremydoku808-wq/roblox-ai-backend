# Kopieer dit naar .env voor lokaal testen (nooit committen naar GitHub!)
# Op Render zet je deze zelfde variabelen in het "Environment" tabblad van je service.

# Je Groq API key, gratis aan te maken op https://console.groq.com (geen creditcard nodig)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Zelfverzonnen geheime sleutel. Roblox stuurt deze mee in de header
# X-Roblox-Secret, zodat alleen jouw game deze backend kan aanroepen.
ROBLOX_SHARED_SECRET=verzin-hier-iets-lang-en-random

# Poort waarop de server luistert (Render zet dit automatisch, lokaal is 3000 prima)
PORT=3000
